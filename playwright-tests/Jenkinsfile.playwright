pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Run Playwright test in Node Container'){
            agent {
                docker {
                    image 'node:20-bullseye'
                    reuseNode true
                    args '-u root'
                }
            }

            steps {
                dir('playwright-tests') {
                    sh 'npm ci'
                    sh 'npx playwright install --with-deps'
                    sh 'npx playwright test'
                }
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'playwright-tests/playwright-report/**', allowEmptyArchive: true
            archiveArtifacts artifacts: 'playwright-tests/test-results/**', allowEmptyArchive: true
        }
        failure {
            mail to: 'jasondstrang@gmail.com',
            subject: "FAILED: ${env.JOB_NAME} Build #${env.BUILD_NUMBER}",
            body:
            "Playwright tests failed! Check the report: ${env.BUILD_URL}\nConsole output: ${env.BUILD_URL}console \nView report artifacts: ${env.BUILD_URL}artifact/playwright-tests/playwright-report/"
        }
        success{
            mail to: 'jasondstrang@gmail.com',
            subject: "PASSED: ${env.JOB_NAME} Build #${env.BUILD_NUMBER}",
            body:
            "Playwright tests passed! Check the report: ${env.BUILD_URL}\nConsole output: ${env.BUILD_URL}console \nView report artifacts: ${env.BUILD_URL}artifact/playwright-tests/playwright-report/"
        }
    }
}